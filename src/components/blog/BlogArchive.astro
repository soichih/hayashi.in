---
import type { CollectionEntry } from 'astro:content';
import { ChevronsRight } from 'lucide-astro';
import FormattedDate from '../FormattedDate.astro';
import MetadataItem from '../MetadataItem.astro';
import SmartImage from '../SmartImage.astro';
import { slugifyGroupName } from '../../utils/content-groups';
import { isStickyEntry } from '../../utils/content-dates';

type BlogPost = CollectionEntry<'blog'>;
type CoverImageStyle = 'card' | 'mask';

interface PaginationState {
  currentPage: number;
  lastPage: number;
  total: number;
  size: number;
  url: {
    current: string;
    prev?: string;
    next?: string;
  };
}

interface Props {
  page: PaginationState & {
    data: BlogPost[];
  };
  postOffset?: number;
  headerKicker?: string;
  headerTitle?: string;
  headerSubtitle?: string;
  headerNote?: string;
  coverImageStyle?: CoverImageStyle;
}

const {
  page,
  postOffset = 0,
  headerKicker = 'Notebook archive',
  headerTitle = 'Writing notes',
  headerSubtitle,
  headerNote,
  coverImageStyle = 'card',
} = Astro.props;
const defaultHeaderSubtitle =
  'Loose pages, technical margins, and small notes gathered into a readable stack.';
const resolvedHeaderSubtitle = headerSubtitle ?? headerNote ?? defaultHeaderSubtitle;
const resolvedHeaderNote = headerSubtitle !== undefined ? headerNote : undefined;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const hasPagination = page.lastPage > 1;

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function getPageHref(pageNumber: number) {
  return pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`;
}
---

<header class="archive-hero archive-header-shared page-header-spacing">
  <div class="archive-header-main">
    <p class="archive-kicker">{headerKicker}</p>
    <h1 class="archive-title">{headerTitle}</h1>
  </div>
  <div class="archive-copy">
    <p class="archive-subtitle">{resolvedHeaderSubtitle}</p>
    {resolvedHeaderNote && <p class="archive-note">{resolvedHeaderNote}</p>}
  </div>
</header>
<slot name="after-header" />
<section>
  <ul class="post-stack">
    {
      page.data.map((post, index) => (
        <li class="post-item">
          <article
            class:list={[
              'post-link',
              `cover-style-${coverImageStyle}`,
              { 'without-thumb': !post.data.heroImage },
            ]}
            data-archive-post-href={withBase(`/blog/${post.id}/`)}
          >
            <div class="post-copy">
              <div>
                <h2 class="title">
                  <span class="post-index" aria-hidden="true">
                    <span class="post-index-number">
                      {String(postOffset + index + 1).padStart(2, '0')}
                    </span>
                    <ChevronsRight class="post-index-icon" size={20} strokeWidth={1.9} />
                  </span>
                  <a class="title-link" href={withBase(`/blog/${post.id}/`)}>
                    {post.data.title}
                  </a>
                  {isStickyEntry(post) && <span class="post-pin">Pinned</span>}
                </h2>
                <div class="date">
                  <MetadataItem kind="date" separated={false}>
                    <FormattedDate date={post.data.date} />
                  </MetadataItem>
                  {post.data.categories.length > 0 && (
                    <MetadataItem kind="categories" class="post-groups">
                      <span class="meta-label">Categories</span>
                      {post.data.categories.map((category) => (
                        <a
                          class="post-group"
                          href={withBase(`/blog/categories/${slugifyGroupName(category)}/`)}
                        >
                          {category}
                        </a>
                      ))}
                    </MetadataItem>
                  )}
                  {post.data.series.length > 0 && (
                    <MetadataItem kind="series" class="post-groups">
                      <span class="meta-label">Series</span>
                      {post.data.series.map((series) => (
                        <a
                          class="post-group"
                          href={withBase(`/blog/series/${slugifyGroupName(series)}/`)}
                        >
                          {series}
                        </a>
                      ))}
                    </MetadataItem>
                  )}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <MetadataItem kind="tags" class="post-tags">
                      {post.data.tags.map((tag) => (
                        <a class="post-tag" href={withBase(`/tags/${slugifyGroupName(tag)}/`)}>
                          #{tag}
                        </a>
                      ))}
                    </MetadataItem>
                  )}
                </div>
              </div>
              <p class="post-excerpt">{post.data.description}</p>
            </div>
            {post.data.heroImage && (
              <a
                class="thumb-wrap"
                href={withBase(`/blog/${post.id}/`)}
                aria-label={post.data.title}
              >
                <SmartImage width={520} height={360} src={post.data.heroImage} alt="" />
              </a>
            )}
          </article>
        </li>
      ))
    }
  </ul>
</section>
{
  hasPagination && (
    <nav class="archive-pagination" aria-label="Blog pagination">
      <a
        class:list={['pagination-link', { disabled: !page.url.prev }]}
        href={page.url.prev ? withBase(page.url.prev) : undefined}
        aria-disabled={!page.url.prev}
      >
        Previous
      </a>
      <div class="pagination-pages" aria-label={`Page ${page.currentPage} of ${page.lastPage}`}>
        {Array.from({ length: page.lastPage }, (_, index) => {
          const pageNumber = index + 1;
          const isCurrent = pageNumber === page.currentPage;

          return (
            <a
              class:list={['pagination-number', { current: isCurrent }]}
              href={withBase(getPageHref(pageNumber))}
              aria-current={isCurrent ? 'page' : undefined}
            >
              {pageNumber}
            </a>
          );
        })}
      </div>
      <a
        class:list={['pagination-link', { disabled: !page.url.next }]}
        href={page.url.next ? withBase(page.url.next) : undefined}
        aria-disabled={!page.url.next}
      >
        Next
      </a>
    </nav>
  )
}

<script is:inline>
  (() => {
    if (window.__navfolioArchivePostClick) return;

    window.__navfolioArchivePostClick = true;

    document.addEventListener('click', (event) => {
      if (event.button !== 0 || event.ctrlKey || event.metaKey || event.shiftKey || event.altKey) {
        return;
      }

      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('a, button, input, select, textarea, summary, [data-no-card-click]')) {
        return;
      }

      const selection = window.getSelection?.();
      if (selection && selection.type === 'Range') return;

      const post = target.closest('[data-archive-post-href]');
      if (!(post instanceof HTMLElement)) return;

      const link = post.querySelector('.title-link');
      if (link instanceof HTMLElement) {
        link.click();
        return;
      }

      const href = post.dataset.archivePostHref;
      if (href) window.location.href = href;
    });
  })();
</script>

<style>
  .post-stack {
    display: grid;
    gap: 0;
    padding: 0;
    list-style: none;
  }

  .post-item {
    position: relative;
  }

  .post-link {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px;
    gap: 30px;
    align-items: center;
    box-sizing: border-box;
    height: 200px;
    padding: 26px 0;
    overflow: visible;
    border: 1px solid var(--paper-line);
    border-width: 1px 0 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    color: var(--paper-ink);
    cursor: pointer;
    transform: translateY(0);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .post-link::before,
  .post-link::after {
    content: none;
  }

  .post-link:hover {
    border-color: var(--paper-line);
    box-shadow: none;
    transform: translateY(-1px);
  }

  .post-link.without-thumb,
  .post-item:first-child .post-link.without-thumb {
    grid-template-columns: minmax(0, 1fr);
    min-height: auto;
  }

  .post-link.cover-style-mask {
    grid-template-columns: minmax(0, 1fr);
    overflow: hidden;
  }

  .post-link.cover-style-mask .post-copy {
    width: min(64%, 720px);
  }

  .post-copy {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: space-between;
    gap: 0;
    min-width: 0;
  }

  .post-copy > div {
    min-width: 0;
  }

  .post-index {
    position: relative;
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    align-self: center;
    width: 2.6ch;
    height: 1.2em;
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.86rem;
    letter-spacing: 0.1em;
  }

  .post-index-number {
    position: absolute;
    inset: 0;
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 240ms ease,
      transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .post-index-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.4em;
    height: 1.4em;
    color: var(--paper-ink-faint);
    opacity: 0;
    transform: translate(-50%, -50%) translateX(-6px);
    transition:
      opacity 240ms ease,
      transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .post-link:hover .post-index-number {
    opacity: 0;
    transform: translateX(5px);
  }

  .post-link:hover .post-index-icon {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  .title {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    align-items: baseline;
    margin: 0;
    font-size: clamp(1.28rem, 2vw, 1.72rem);
    line-height: 1.24;
  }

  .title-link {
    position: relative;
    display: inline-block;
    min-width: 0;
    margin: 0 -2px -2px;
    padding: 0 2px 2px;
    color: var(--paper-ink);
    text-decoration: none;
    transition: color 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .title-link::before {
    position: absolute;
    right: 2px;
    bottom: 0;
    left: 2px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--paper-line-strong) 16%,
      var(--paper-accent) 52%,
      var(--paper-line-strong) 84%,
      transparent
    );
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition:
      transform 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background-color 350ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .title-link:hover {
    color: var(--paper-accent);
  }

  .title-link:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }

  .post-pin {
    display: inline-flex;
    align-items: center;
    min-height: 21px;
    padding: 1px 7px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: var(--paper-control);
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.2;
    vertical-align: 0.12em;
  }

  .post-link.without-thumb .title {
    max-width: none;
  }

  .date {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    align-items: center;
    margin: 10px 0 0;
    color: var(--paper-ink-soft);
    font-family: var(--font-meta);
    font-size: 0.86rem;
    font-weight: 600;
  }

  :global(.post-tags) {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .post-tag {
    color: var(--paper-accent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .post-tag:hover {
    color: var(--paper-ink);
  }

  .post-tag:focus-visible,
  .post-group:focus-visible,
  .title-link:focus-visible,
  .thumb-wrap:focus-visible {
    border-radius: 4px;
    outline: 2px solid var(--paper-line-strong);
    outline-offset: 3px;
  }

  .post-tag + .post-tag::before,
  .post-group + .post-group::before {
    margin: 0 6px;
    color: var(--paper-ink-faint);
    content: '\00b7';
  }

  :global(.post-groups) {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  .meta-label {
    margin-right: 6px;
    color: var(--paper-ink-faint);
  }

  :global(.metadata-item-icon) .meta-label {
    display: none;
  }

  .post-group {
    color: var(--paper-accent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .post-group:hover {
    color: var(--paper-ink);
  }

  .post-excerpt {
    margin: 0;
    color: var(--paper-ink-soft);
    font-size: 0.98rem;
    line-height: 1.78;
  }

  .thumb-wrap {
    position: relative;
    z-index: 1;
    align-self: center;
    width: 210px;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: var(--paper-surface-muted);
    filter: saturate(0.86) contrast(0.98);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 18px 100%, 0 calc(100% - 18px));
  }

  .post-link.cover-style-mask .thumb-wrap {
    position: absolute;
    top: 50%;
    right: 0;
    z-index: 0;
    width: min(38%, 520px);
    height: min(calc(100% - 52px), 200px);
    border: 0;
    border-radius: 0 10px 10px 0;
    background: transparent;
    clip-path: none;
    filter: saturate(0.82) contrast(0.96);
    opacity: 0.72;
    mask-image:
      linear-gradient(to right, transparent, #000 48%),
      radial-gradient(140% 120% at 100% 50%, #000 54%, transparent 76%);
    mask-composite: intersect;
    transform: translateY(-50%);
    transition:
      opacity 200ms ease,
      filter 200ms ease;
    -webkit-mask-image:
      linear-gradient(to right, transparent, #000 48%),
      radial-gradient(140% 120% at 100% 50%, #000 54%, transparent 76%);
    -webkit-mask-composite: source-in;
  }

  .post-link.cover-style-mask:hover .thumb-wrap {
    filter: saturate(0.9) contrast(0.98);
    opacity: 0.9;
  }

  .thumb-wrap img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    mix-blend-mode: normal;
    opacity: 0.92;
  }

  .post-link.cover-style-mask .thumb-wrap img {
    opacity: 1;
  }

  :root[data-theme='dark'] .thumb-wrap {
    background: transparent;
    filter: none;
  }

  :root[data-theme='dark'] .thumb-wrap img {
    opacity: 1;
    mix-blend-mode: normal;
  }

  :root[data-theme='dark'] .post-link.cover-style-mask .thumb-wrap {
    opacity: 0.62;
  }

  :root[data-theme='dark'] .post-link.cover-style-mask:hover .thumb-wrap {
    opacity: 0.82;
  }

  .post-item:first-child .post-link {
    grid-template-columns: minmax(0, 1fr) 210px;
    min-height: 132px;
    padding: 26px 0;
  }

  .post-item:first-child .title {
    font-size: clamp(1.36rem, 2.2vw, 1.9rem);
  }

  .archive-pagination {
    display: grid;
    grid-template-columns: minmax(98px, auto) minmax(0, 1fr) minmax(98px, auto);
    gap: 16px;
    align-items: center;
    margin-top: 34px;
    padding-top: 20px;
    border-top: 1px solid var(--paper-line);
    font-family: var(--font-meta);
    font-size: 0.82rem;
  }

  .pagination-pages {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .pagination-link,
  .pagination-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: var(--paper-control);
    color: var(--paper-ink-soft);
    text-decoration: none;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .pagination-link {
    padding: 0 14px;
  }

  .pagination-number {
    min-width: 36px;
    padding: 0 10px;
  }

  .pagination-link:hover,
  .pagination-number:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-ink);
    transform: translateY(-1px);
  }

  .pagination-number.current {
    border-color: var(--paper-line-strong);
    background: var(--paper-surface);
    color: var(--paper-accent);
  }

  .pagination-link.disabled {
    pointer-events: none;
    opacity: 0.45;
  }

  @media (max-width: 720px) {
    .post-link,
    .post-item:first-child .post-link {
      display: flex;
      flex-direction: column;
      grid-template-columns: 1fr;
      gap: 18px;
      height: auto;
      padding: 22px 0;
    }

    .thumb-wrap {
      width: 100%;
      aspect-ratio: 16 / 9;
      order: -1;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    }

    .post-link.cover-style-mask {
      overflow: visible;
    }

    .post-link.cover-style-mask .post-copy {
      order: 1;
      width: auto;
    }

    .post-link.cover-style-mask .thumb-wrap {
      position: relative;
      inset: auto;
      top: auto;
      width: 100%;
      height: auto;
      max-height: 256px;
      margin-bottom: 0;
      aspect-ratio: 16 / 9;
      border-radius: 14px 14px 0 0;
      clip-path: inset(0 round 14px 14px 0 0);
      opacity: 0.78;
      order: -1;
      transform: none;
      mask-image:
        linear-gradient(to bottom, #000 62%, transparent),
        radial-gradient(120% 120% at 50% 0, #000 58%, transparent 82%);
      mask-composite: intersect;
      -webkit-mask-image:
        linear-gradient(to bottom, #000 62%, transparent),
        radial-gradient(120% 120% at 50% 0, #000 58%, transparent 82%);
      -webkit-mask-composite: source-in;
    }

    .title,
    .post-item:first-child .title {
      display: grid;
      grid-template-columns: 2.6ch minmax(0, 1fr);
      min-width: 0;
      max-width: 100%;
      gap: 8px;
      align-items: baseline;
      font-size: 1.45rem;
      line-height: 1.22;
    }

    .title-link {
      display: block;
      min-width: 0;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .post-pin {
      grid-column: 2;
      margin-top: 7px;
    }

    .date {
      display: flex;
      flex-wrap: wrap;
      gap: 4px 12px;
      margin-top: 8px;
      font-size: 0.78rem;
      line-height: 1.45;
    }

    .date :global(.metadata-item-icon.metadata-item-separated) {
      margin-inline-start: 0;
    }

    :global(.post-tags),
    :global(.post-groups) {
      display: flex;
      flex-wrap: wrap;
      min-width: 0;
      max-width: 100%;
      overflow: visible;
      white-space: normal;
    }

    .meta-label {
      display: none;
    }

    :global(.post-groups) {
      max-width: 100%;
    }

    :global(.post-tags) {
      flex-basis: 100%;
      max-width: 100%;
    }

    .post-tag,
    .post-group {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .archive-pagination {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 28px;
    }

    .pagination-link,
    .pagination-pages {
      width: 100%;
    }
  }
</style>
